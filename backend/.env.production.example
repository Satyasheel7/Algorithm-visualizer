# Production Environment Variables
# Copy these to your deployment platform (Render/Railway)
# IMPORTANT: Generate new JWT secrets for production!

# Server Configuration
NODE_ENV=production
PORT=5000

# JWT Secrets - GENERATED SECURE SECRETS (Use these in production)
# Generate your own production secrets and store them in Render
JWT_SECRET=
REFRESH_TOKEN_SECRET=

# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.xxxxx.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Gemini API (for AI code fixing)
GEMINI_API_KEY=

# CORS - Your production frontend URL
FRONTEND_URL=https://algorithm-visualizer-git-main-satyasheel7s-projects.vercel.app
